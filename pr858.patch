From 092d00082eb6a0e38c69a2a256709717a5cd2701 Mon Sep 17 00:00:00 2001
From: fanzhang <4030914+tonyjohnvan@users.noreply.github.com>
Date: Mon, 16 Mar 2026 12:20:03 -0400
Subject: [PATCH 42/53] fix(llm_inference): include full traceback in batch
 codes generation error

When batch codes generation fails, error_msg previously contained only
str(e). Now includes type(e).__name__, the exception message, and
traceback.format_exc() for complete diagnostic context. Improves
debuggability when batch generation raises; caller receives full
stack trace in metadata/response for log analysis.

Made-with: Cursor
---
 acestep/llm_inference.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/acestep/llm_inference.py b/acestep/llm_inference.py
index 72548290..9ca08819 100644
--- a/acestep/llm_inference.py
+++ b/acestep/llm_inference.py
@@ -1372,7 +1372,7 @@ def progress(*args, **kwargs):
                         seeds=seeds,
                     )
             except Exception as e:
-                error_msg = f"Error in batch codes generation: {str(e)}"
+                error_msg = f"Error in batch codes generation: {type(e).__name__}: {e}\n{traceback.format_exc()}"
                 logger.error(error_msg)
                 return {
                     "metadata": [],

