From e6c6e147955813f7f2d61d34201c830db552b172 Mon Sep 17 00:00:00 2001
From: fanzhang <4030914+tonyjohnvan@users.noreply.github.com>
Date: Tue, 17 Mar 2026 16:47:36 -0400
Subject: [PATCH 45/53] fix(customized_vllm): add capacity guard in
 CachePool.grow_if_needed and input validation in _prepare_slots

Address CodeRabbit review issues #1 and #2 from PR #858:

1. CachePool.grow_if_needed() now checks block availability before
   attempting to allocate. Previously, calling popleft() on an empty
   deque would raise an IndexError with no diagnostic context. The new
   guard raises a descriptive RuntimeError identifying the slot and
   remaining capacity.

2. LLM._prepare_slots() now validates that sampling_params and
   unconditional_prompts lists match the prompts length after
   broadcasting. Previously, a length mismatch would silently zip
   to the shortest list, producing fewer slots than expected.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 acestep/customized_vllm/__init__.py | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/acestep/customized_vllm/__init__.py b/acestep/customized_vllm/__init__.py
index 8dc53201..0bf63197 100644
--- a/acestep/customized_vllm/__init__.py
+++ b/acestep/customized_vllm/__init__.py
@@ -181,6 +181,11 @@ def release(self, slot: GenerationSlot):
 
     def grow_if_needed(self, slot: GenerationSlot):
         if len(slot) % self.block_size == 1 and len(slot) > slot.prompt_length:
+            if not self.available:
+                raise RuntimeError(
+                    f"KV cache exhausted during decode: slot {slot.slot_id} needs a new block "
+                    f"but 0/{self.total} blocks are available"
+                )
             slot.cache_blocks.append(self.available.popleft())
 
 
@@ -275,6 +280,14 @@ def _prepare_slots(self, prompts, sampling_params, unconditional_prompts):
             sampling_params = [sampling_params] * len(prompts)
         if unconditional_prompts is None:
             unconditional_prompts = [None] * len(prompts)
+        if len(sampling_params) != len(prompts):
+            raise ValueError(
+                f"sampling_params length ({len(sampling_params)}) != prompts length ({len(prompts)})"
+            )
+        if len(unconditional_prompts) != len(prompts):
+            raise ValueError(
+                f"unconditional_prompts length ({len(unconditional_prompts)}) != prompts length ({len(prompts)})"
+            )
 
         all_slots = []
         for prompt, sp, uncond in zip(prompts, sampling_params, unconditional_prompts):

From bca74249dada86392ba47ea0278cbe3ea7124454 Mon Sep 17 00:00:00 2001
From: fanzhang <4030914+tonyjohnvan@users.noreply.github.com>
