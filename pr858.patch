From 082ffba2310c4f89da73297ca05b10709a4ad1c5 Mon Sep 17 00:00:00 2001
From: fanzhang <4030914+tonyjohnvan@users.noreply.github.com>
Date: Tue, 17 Mar 2026 17:20:18 -0400
Subject: [PATCH 49/53] fix(customized_vllm): propagate kvcache_block_size to
 GenerationSlot instances
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

GenerationSlot.block_size was hardcoded as a class-level constant (256),
meaning required_blocks and tail_block_fill calculations would silently
produce wrong values if a non-default kvcache_block_size was configured
via LLM(kvcache_block_size=...).

Change block_size from a class attribute to an instance attribute set in
__init__(block_size=256), and thread it through from:
  - LLM.__init__ → self._block_size
  - LLM._prepare_slots → GenerationSlot(..., block_size=self._block_size)

Uses getattr(self, '_block_size', 256) so test stubs that bypass
LLM.__init__ still get the correct default.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 acestep/customized_vllm/__init__.py | 10 ++++++----
 1 file changed, 6 insertions(+), 4 deletions(-)

diff --git a/acestep/customized_vllm/__init__.py b/acestep/customized_vllm/__init__.py
index 0bf63197..52df46bc 100644
--- a/acestep/customized_vllm/__init__.py
+++ b/acestep/customized_vllm/__init__.py
@@ -102,11 +102,11 @@ class GenerationSlot:
     """Tracks token state, cache blocks, and sampling config for a single sequence."""
 
     _id_gen = count()
-    block_size = 256
 
     def __init__(self, token_ids: list[int], params=SamplingParams(),
-                 is_unconditional: bool = False):
+                 is_unconditional: bool = False, block_size: int = 256):
         self.slot_id = next(GenerationSlot._id_gen)
+        self.block_size = block_size
         self.status = SlotStatus.PENDING
         self.token_ids = copy(token_ids)
         self.last_token = token_ids[-1]
@@ -248,6 +248,7 @@ def __init__(self, model, **kwargs):
         tok = kwargs.get("tokenizer", None)
         self.tokenizer = tok if tok is not None else AutoTokenizer.from_pretrained(model, use_fast=True)
         self._eos = self.tokenizer.eos_token_id
+        self._block_size = cfg.kvcache_block_size
         self._cache = CachePool(self._pipeline._num_cache_blocks, cfg.kvcache_block_size)
         self._active_slots: list[GenerationSlot] = []
         atexit.register(self.exit)
@@ -292,11 +293,12 @@ def _prepare_slots(self, prompts, sampling_params, unconditional_prompts):
         all_slots = []
         for prompt, sp, uncond in zip(prompts, sampling_params, unconditional_prompts):
             ids = self.tokenizer.encode(prompt) if isinstance(prompt, str) else prompt
-            cond = GenerationSlot(ids, sp)
+            bs = getattr(self, '_block_size', 256)
+            cond = GenerationSlot(ids, sp, block_size=bs)
             if sp.cfg_scale > 1.0:
                 u_ids = (self.tokenizer.encode(uncond) if isinstance(uncond, str)
                          else (uncond if uncond is not None else ids))
-                uncond_slot = GenerationSlot(u_ids, sp, is_unconditional=True)
+                uncond_slot = GenerationSlot(u_ids, sp, is_unconditional=True, block_size=bs)
                 cond.paired_slot = uncond_slot
                 uncond_slot.paired_slot = cond
                 all_slots.extend([cond, uncond_slot])

