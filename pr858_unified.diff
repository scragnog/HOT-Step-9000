-    Args:
-        tensor: Tensor to reduce
-        op: Reduce operation (default: SUM)
-    """
-    if _distributed_initialized:
-        if op is None:
-            op = dist.ReduceOp.SUM
-        dist.all_reduce(tensor, op)
-
-
