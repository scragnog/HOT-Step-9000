-        value: [N, num_kv_heads, head_dim]
-        k_cache: [num_blocks, block_size, num_kv_heads, head_dim] (per-layer view)
-        v_cache: [num_blocks, block_size, num_kv_heads, head_dim]
-        slot_mapping: [N] - flat slot indices into cache
